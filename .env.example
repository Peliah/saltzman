# Copy to `.env` / Vercel. Leave empty only if you skip Convex locally (guest book disabled).

# Convex — run `pnpm exec convex dev` and paste deployment URL
PUBLIC_CONVEX_URL=

# OpenRouter — server only (SvelteKit `/api/chat`)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-haiku

# Optional OpenRouter attribution
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_NAME=Portfolio

# EmailJS (public keys — safe in client)
PUBLIC_EMAILJS_SERVICE_ID=
PUBLIC_EMAILJS_TEMPLATE_ID=
PUBLIC_EMAILJS_PUBLIC_KEY=
